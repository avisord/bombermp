# Staging environment template.
# Copy to .env.stage and fill in secrets — this file is committed, .env.stage is NOT.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
MONGODB_URI=                                               # Stage MongoDB URI
CLIENT_ORIGIN=https://stage.bombermb.avinashjha.space
COOKIE_SECRET=                                             # openssl rand -hex 32

# ─── Client build args (baked into Vite bundle at docker build time) ──────────
VITE_WS_URL=wss://stage.bombermbapi.avinashjha.space
VITE_API_URL=https://stage.bombermbapi.avinashjha.space
