# Production environment template.
# Copy to .env.prod and fill in secrets — this file is committed, .env.prod is NOT.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
MONGODB_URI=                                          # MongoDB Atlas URI or mongodb://mongodb:27017/bombermp
CLIENT_ORIGIN=https://bombermb.avinashjha.space
COOKIE_SECRET=                                        # openssl rand -hex 32

# ─── Client build args (baked into Vite bundle at docker build time) ──────────
VITE_WS_URL=wss://bombermbapi.avinashjha.space
VITE_API_URL=https://bombermbapi.avinashjha.space
